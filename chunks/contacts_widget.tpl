<div class="contacts-widget">
    
    <div class="contacts-widget__icon-wrapper">
        <div class="contacts-widget__icon-background-back"></div>
        <div class="contacts-widget__icon-background-front"></div>
        <div class="contacts-widget__title">Свяжитесь с нами</div>
        <img src="/assets/img/icons/chat.png" alt="свяжитесь с нами" class="contacts-widget__icon">
    </div>
    
    <div class="contacts-widget__hover-wrapper">
        
        <div class="contacts-widget__hover">
            <div class="contacts-widget__hover-content">
                <div class="contacts-widget__hover-items">
                    
                    <div data-hystmodal="#header-request" class="contacts-widget__hover-item">
                        <img src="/assets/img/icons/mail.svg" alt="Напишите нам" class="contacts-widget__hover-item-img">
                        <div class="contacts-widget__hover-item-text">
                            Отправить заявку менеджеру
                        </div>
                    </div>
                    <a target="_blank" href="[[++phone]]" class="contacts-widget__hover-item">
                        <img src="/assets/img/icons/call.svg" alt="позвонить" class="contacts-widget__hover-item-img">
                        <div class="contacts-widget__hover-item-text">
                            [[++phone]]
                        </div>
                    </a>
                    <a target="_blank" href="[[++max]]" class="contacts-widget__hover-item">
                        <img src="/assets/img/icons/MAX.svg" alt="написать в max" class="contacts-widget__hover-item-img">
                        <div class="contacts-widget__hover-item-text">
                           MAX 
                        </div>
                    </a>
                    <a target="_blank" href="[[++telegram]]" class="contacts-widget__hover-item">
                        <img src="/assets/img/icons/telegram-icon.svg" alt="написать в telegram" class="contacts-widget__hover-item-img">
                        <div class="contacts-widget__hover-item-text">
                           Telegram
                        </div>
                    </a>
                    <a target="_blank" href="[[++vk]]" class="contacts-widget__hover-item">
                        <img src="/assets/img/icons/vk-icon.svg" alt="написать в telegram" class="contacts-widget__hover-item-img">
                        <div class="contacts-widget__hover-item-text">
                            Вконтакте
                        </div>
                    </a>

                </div>
            </div>
        </div>
    </div>
</div>