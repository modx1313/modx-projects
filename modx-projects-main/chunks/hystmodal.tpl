<div class="hystmodal" id="tickets-modal" aria-hidden="true">
    <div class="hystmodal__wrap">
        <div class="hystmodal__window modal-wrapper tickets-modal" role="dialog" aria-modal="true">
            <div class="wrapper">
                
                <button data-hystclose class="hystmodal__close">Закрыть</button>
                [[$ticketsModal]]
            </div>
        </div>
    </div>
</div>

<div class="hystmodal" id="gifts-modal" aria-hidden="true">
    <div class="hystmodal__wrap">
        <div class="hystmodal__window modal-wrapper" role="dialog" aria-modal="true">
            <button data-hystclose class="hystmodal__close">Закрыть</button>
            [[$giftsModal]]
        </div>
    </div>
</div>

<div class="hystmodal" id="question-modal" aria-hidden="true">
    <div class="hystmodal__wrap">
        <div class="hystmodal__window modal-wrapper" role="dialog" aria-modal="true">
            [[$questionModal]] 
            <button data-hystclose class="hystmodal__close">Закрыть</button>
        </div>
    </div>
</div>

<div class="hystmodal" id="success-modal" aria-hidden="true">
    <div class="hystmodal__wrap">
        <div class="hystmodal__window modal-wrapper" role="dialog" aria-modal="true">
            <div class="success-message-modal">
                Спасибо за Ваше обращение, мы свяжемся с Вами в самое ближайшее время
            </div>
            <button data-hystclose class="hystmodal__close">Закрыть</button>
        </div>
    </div>
</div>